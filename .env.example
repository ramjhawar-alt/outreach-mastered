# ──────────────────────────────────────────────────────────────
# Google Sheets (required for sheet export)
# ──────────────────────────────────────────────────────────────
# Service account JSON key — get from Google Cloud Console:
#   APIs & Services > Credentials > Create Service Account > Keys > Add Key > JSON
GOOGLE_CREDENTIALS_PATH=credentials.json

# ──────────────────────────────────────────────────────────────
# Gmail outreach (required for --email)
# ──────────────────────────────────────────────────────────────
# App password: Google Account > Security > 2-Step Verification > App passwords
GMAIL_FROM=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Delay between emails (seconds)
EMAIL_DELAY_SEC=3
# Random delay range for --email-daily (seconds)
# EMAIL_DELAY_MIN_SEC=60
# EMAIL_DELAY_MAX_SEC=180
# Max emails per calendar day (--email-daily)
# EMAIL_DAILY_LIMIT=50

# Default sheet for --email-daily (so you can omit --from-sheet)
# OUTREACH_SHEET_ID=your_sheet_id_here

# PDF to attach to every outreach email (absolute or relative path)
# OUTREACH_RESUME_PDF=/path/to/Resume.pdf

# Optional: comma-separated Gmail "Send mail as" aliases (improves reply sync matching)
# GMAIL_FROM_ALIASES=other@gmail.com,alias@company.org
# Set to 1 for verbose IMAP debug output during --sync-email-replies
# OUTREACH_SYNC_VERBOSE=1

# ──────────────────────────────────────────────────────────────
# Apollo.io — founder/CEO email lookup (optional)
# ──────────────────────────────────────────────────────────────
# Get your API key: https://app.apollo.io/#/settings/integrations/api
# APOLLO_API_KEY=your_apollo_api_key
# Comma-separated titles to search for (default: Founder,CEO,Co-Founder,CTO)
# APOLLO_CONTACT_TITLES=Founder,CEO,Co-Founder,CTO

# ──────────────────────────────────────────────────────────────
# Org enrichment: web search + LLM (optional, for --enrich-org)
# ──────────────────────────────────────────────────────────────
# Priority order for the LLM phrase step: "groq" or "openrouter" (other is fallback)
# ENRICH_LLM_PRIMARY=groq

# Groq (free tier) — https://console.groq.com/
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter — https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=arcee-ai/trinity-large-preview:free
# OPENROUTER_ENRICH_GAP_SEC=5

# Web search provider (picks first available: You.com > Brave > Google CSE)
# You.com / YDC — https://documentation.you.com/
# YDC_API_KEY=ydc-sk-...
# Brave Search — https://api-dashboard.search.brave.com/
# BRAVE_API_KEY=
# BRAVE_SEARCH_COUNT=10
# Google Custom Search (fallback) — https://programmablesearchengine.google.com
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
