# Google Sheets — service account JSON key
GOOGLE_CREDENTIALS_PATH=credentials.json

# Gmail — for sending outreach emails
GMAIL_FROM=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# You.com — web search for org enrichment (free)
YDC_API_KEY=ydc-sk-...

# Groq — LLM for "What they do" phrases (free)
GROQ_API_KEY=gsk_...
ENRICH_LLM_PRIMARY=groq

# OpenRouter — fallback LLM (free models available)
OPENROUTER_API_KEY=sk-or-v1-...

# Apollo.io — find founder/CEO emails (free search; 1 credit to reveal email, only when you explicitly ask)
APOLLO_API_KEY=your_apollo_api_key

# Default sheet for --email-daily (so you can omit --from-sheet)
OUTREACH_SHEET_ID=your_sheet_id_here

# PDF attached to every outreach email — drop your file in attachments/
# OUTREACH_RESUME_PDF=attachments/YourResume.pdf
